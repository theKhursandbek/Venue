# Production Environment Variables
# Copy this file to .env.prod and update values

# =============================================================================
# Django Settings
# =============================================================================
SECRET_KEY=your-very-secure-production-secret-key-change-this
DEBUG=False
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
POSTGRES_DB=venue_booking_prod
POSTGRES_USER=venue_user
POSTGRES_PASSWORD=super-secure-database-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
DB_CONN_MAX_AGE=60

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://redis:6379/0

# =============================================================================
# Security
# =============================================================================
SECURE_SSL_REDIRECT=True
ADMIN_URL=secret-admin-path/

# =============================================================================
# JWT Configuration
# =============================================================================
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7

# =============================================================================
# OTP Configuration
# =============================================================================
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_MINUTES=10

# =============================================================================
# CORS
# =============================================================================
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# =============================================================================
# Email (for error notifications)
# =============================================================================
EMAIL_HOST=smtp.your-email-provider.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
SERVER_EMAIL=noreply@your-domain.com
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@your-domain.com
